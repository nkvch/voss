# Backend
VOSS_HOST=0.0.0.0
VOSS_PORT=8000
VOSS_UPLOAD_DIR=/app/uploads
VOSS_DATABASE_PATH=/app/data/voss.db
VOSS_LOG_LEVEL=INFO
VOSS_LOG_FORMAT=json
VOSS_MAX_FILE_SIZE_MB=50
VOSS_STAGE_MIN_DELAY_S=2.0
VOSS_STAGE_MAX_DELAY_S=5.0
VOSS_MAX_RETRY_COUNT=3

# Ports (for docker-compose)
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=80
